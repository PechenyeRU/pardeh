{
  "manifest_version": 3,
  "name": "Pardeh",
  "version": "1.1.0",
  "description": "End-to-end encryption overlay for Bale Web.",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://web.bale.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pardeh"
  },
  "content_scripts": [
    {
      "matches": ["https://web.bale.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
