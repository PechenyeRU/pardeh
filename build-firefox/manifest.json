{
  "manifest_version": 2,
  "name": "Pardeh",
  "version": "1.1.0",
  "description": "End-to-end encryption overlay for Bale Web.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "pardeh@e2e-encryption.bale.ai",
      "strict_min_version": "115.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Pardeh"
  },
  "content_scripts": [
    {
      "matches": ["https://web.bale.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
